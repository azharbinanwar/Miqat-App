<?xml version="1.0" encoding="utf-8"?>
<!-- Dark prayer card (design 8b), native RemoteViews. Current prayer + live countdown + app-icon badge,
     and the five times across the bottom. Text/colors filled in code; defaults here so the picker preview reads. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background panel as an ImageView so its opacity (setImageAlpha) can fade to reveal the wallpaper. -->
    <ImageView android:id="@+id/bg"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:scaleType="fitXY" android:src="@drawable/widget_gradient_bg" android:contentDescription="@null" />

    <!-- App mark, faint, bled off the bottom-right corner. -->
    <ImageView android:id="@+id/watermark"
        android:layout_width="160dp" android:layout_height="160dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="-36dp" android:layout_marginBottom="-36dp"
        android:src="@drawable/miqat_watermark" android:tint="#FFFFFF"
        android:alpha="0.06" android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="20dp" android:paddingEnd="20dp"
        android:paddingTop="18dp" android:paddingBottom="16dp">

        <!-- Top: current prayer + countdown (left), app-icon badge (right) -->
        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <LinearLayout
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView android:id="@+id/label"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="NOW" android:textColor="#B7CBBE" android:textSize="11sp" android:textStyle="bold" android:letterSpacing="0.08" />
                <TextView android:id="@+id/name"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="3dp" android:text="Dhuhr" android:textColor="#FFFFFF" android:textSize="32sp" android:textStyle="bold" android:maxLines="1" />
                <LinearLayout
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="5dp" android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:id="@+id/nextinfo"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Next · Asr · " android:textColor="#CBD8CF" android:textSize="14sp" android:maxLines="1" />
                    <Chronometer android:id="@+id/chrono"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#CBD8CF" android:textSize="14sp" android:includeFontPadding="false" />
                    <TextView android:id="@+id/chronoStatic"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="in 2h 14m" android:textColor="#CBD8CF" android:textSize="14sp" android:includeFontPadding="false" android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>
            <FrameLayout android:id="@+id/badgebox"
                android:layout_width="50dp" android:layout_height="50dp"
                android:background="@drawable/widget_badge_box">
                <ImageView android:id="@+id/badgeicon"
                    android:layout_width="26dp" android:layout_height="26dp" android:layout_gravity="center"
                    android:src="@drawable/ic_miqat_sun" android:contentDescription="@null" />
            </FrameLayout>
        </LinearLayout>

        <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />

        <FrameLayout android:id="@+id/divider" android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#1FFFFFFF" android:layout_marginBottom="12dp" />

        <!-- Bottom: the other four times (current prayer dropped — it's the header). No dots, bigger. -->
        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center_horizontal">
                <TextView android:id="@+id/t0name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fajr" android:textColor="#D3E0D8" android:textSize="14sp" android:textStyle="bold" android:maxLines="1" />
                <TextView android:id="@+id/t0time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="3:34 AM" android:textColor="#F0F4F1" android:textSize="17sp" android:maxLines="1" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center_horizontal">
                <TextView android:id="@+id/t1name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dhuhr" android:textColor="#D3E0D8" android:textSize="14sp" android:textStyle="bold" android:maxLines="1" />
                <TextView android:id="@+id/t1time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="12:08 PM" android:textColor="#F0F4F1" android:textSize="17sp" android:maxLines="1" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center_horizontal">
                <TextView android:id="@+id/t2name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Maghrib" android:textColor="#D3E0D8" android:textSize="14sp" android:textStyle="bold" android:maxLines="1" />
                <TextView android:id="@+id/t2time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="7:07 PM" android:textColor="#F0F4F1" android:textSize="17sp" android:maxLines="1" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center_horizontal">
                <TextView android:id="@+id/t3name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Isha" android:textColor="#D3E0D8" android:textSize="14sp" android:textStyle="bold" android:maxLines="1" />
                <TextView android:id="@+id/t3time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="8:42 PM" android:textColor="#F0F4F1" android:textSize="17sp" android:maxLines="1" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
