<?xml version="1.0" encoding="utf-8"?>
<!-- Prayer Bar (design 23e) — 4×1. NOW current · NEXT next with a centre divider. Time only, no countdown.
     Colour/opacity from WidgetConfig; text filled in code, sample defaults here for the picker preview. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent" android:layout_height="match_parent">

    <ImageView android:id="@+id/bg" android:layout_width="match_parent" android:layout_height="match_parent"
        android:scaleType="fitXY" android:src="@drawable/widget_gradient_bg" android:contentDescription="@null" />
    <ImageView android:id="@+id/watermark" android:layout_width="120dp" android:layout_height="120dp"
        android:layout_gravity="bottom|end" android:layout_marginEnd="-28dp" android:layout_marginBottom="-28dp"
        android:src="@drawable/miqat_watermark" android:tint="#FFFFFF" android:alpha="0.06" android:contentDescription="@null" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="horizontal" android:gravity="center_vertical" android:baselineAligned="false"
        android:paddingStart="18dp" android:paddingEnd="18dp">
        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
            <TextView android:id="@+id/nowlabel" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="NOW" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.08" />
            <TextView android:id="@+id/nowval" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="2dp" android:text="Dhuhr · 12:34 PM" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:maxLines="1" />
        </LinearLayout>
        <FrameLayout android:id="@+id/divider" android:layout_width="1dp" android:layout_height="32dp" android:layout_marginStart="14dp" android:layout_marginEnd="14dp" android:background="#33FFFFFF" />
        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="end">
            <TextView android:id="@+id/nextlabel" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="NEXT" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.08" android:gravity="end" />
            <TextView android:id="@+id/nextval" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="2dp" android:text="Asr · 3:58 PM" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:maxLines="1" android:gravity="end" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
