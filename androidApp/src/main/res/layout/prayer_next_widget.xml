<?xml version="1.0" encoding="utf-8"?>
<!-- Prayer Next (design 19d) — 2×2. Centred: NEXT PRAYER / name / time. Colour/opacity from WidgetConfig. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent" android:layout_height="match_parent">

    <ImageView android:id="@+id/bg" android:layout_width="match_parent" android:layout_height="match_parent"
        android:scaleType="fitXY" android:src="@drawable/widget_gradient_bg" android:contentDescription="@null" />
    <ImageView android:id="@+id/watermark" android:layout_width="120dp" android:layout_height="120dp"
        android:layout_gravity="bottom|end" android:layout_marginEnd="-26dp" android:layout_marginBottom="-26dp"
        android:src="@drawable/miqat_watermark" android:tint="#FFFFFF" android:alpha="0.07" android:contentDescription="@null" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical" android:gravity="center" android:padding="14dp">
        <TextView android:id="@+id/label" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="NOW" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold" android:letterSpacing="0.08" />
        <TextView android:id="@+id/name" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="6dp" android:text="Asr" android:textColor="#FFFFFF" android:textSize="27sp" android:textStyle="bold" android:maxLines="1" />
        <TextView android:id="@+id/time" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="4dp" android:text="3:58 PM" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" />
    </LinearLayout>
</FrameLayout>
