<?xml version="1.0" encoding="utf-8"?>
<!-- Prayer Chip (design 19i) — 1×1 app-icon size. Corner "Next" + name + time. Colour/opacity from WidgetConfig. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent" android:layout_height="match_parent">

    <ImageView android:id="@+id/bg" android:layout_width="match_parent" android:layout_height="match_parent"
        android:scaleType="fitXY" android:src="@drawable/widget_gradient_bg" android:contentDescription="@null" />
    <ImageView android:id="@+id/watermark" android:layout_width="90dp" android:layout_height="90dp"
        android:layout_gravity="bottom|end" android:layout_marginEnd="-22dp" android:layout_marginBottom="-22dp"
        android:src="@drawable/miqat_watermark" android:tint="#FFFFFF" android:alpha="0.08" android:contentDescription="@null" />

    <TextView android:id="@+id/cornerlabel" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="top|start" android:layout_marginStart="9dp" android:layout_marginTop="9dp"
        android:text="NEXT" android:textColor="#FFFFFF" android:textSize="8sp" android:textStyle="bold" android:letterSpacing="0.06" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical" android:gravity="center" android:paddingTop="6dp">
        <TextView android:id="@+id/name" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Asr" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" android:maxLines="1" />
        <TextView android:id="@+id/time" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="1dp" android:text="3:58" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold" />
    </LinearLayout>
</FrameLayout>
